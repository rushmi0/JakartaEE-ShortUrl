<?xml version="1.0" encoding="UTF-8"?>
<web-fragment xmlns="https://jakarta.ee/xml/ns/jakartaee"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
              https://jakarta.ee/xml/ns/jakartaee/web-fragment_6_0.xsd"
              version="6.0">

    <listener>
        <listener-class>com.brightbetter.extension.shorturl.ShortUrlInit</listener-class>
    </listener>

    <filter>
        <filter-name>ShortUrlFilter</filter-name>
        <filter-class>com.brightbetter.extension.shorturl.ShortUrlFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>ShortUrlFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>


</web-fragment>